[options]
mode bmc
depth 30
expect pass

[engines]
smtbmc yices

[script]
# NOTE: [files] below provides paths relative to the project root (CWD).
# SymbiYosys copies them flat into its work directory, so read -formal
# uses basenames only. Run: sby -f formal.sby from the project root.
read -formal bnn_core.v xnor_popcount.v
prep -top bnn_core

[files]
rtl/bnn_core.v
rtl/xnor_popcount.v
