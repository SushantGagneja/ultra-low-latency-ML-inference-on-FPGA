[options]
mode bmc
depth 30
expect pass

[engines]
smtbmc yices

[script]
# NOTE: [files] below provides paths relative to the project root (CWD).
# SymbiYosys copies them flat into its work directory, so read -formal
# uses basenames only. Run: sby -f formal.sby from the project root.
read_verilog -sv -formal bnn_top.v bnn_core_unrolled.v spi_slave.v tick_parser.v ofi_engine.v lee_ready.v vwap_engine.v sequential_multiplier.v restoring_divider.v bram_microstructure.v hw_quantizer.v
prep -top bnn_top
clk2fflogic

[files]
rtl/bnn_top.v
rtl/bnn_core_unrolled.v
rtl/spi_slave.v
rtl/microstructure/tick_parser.v
rtl/microstructure/ofi_engine.v
rtl/microstructure/lee_ready.v
rtl/microstructure/vwap_engine.v
rtl/microstructure/sequential_multiplier.v
rtl/microstructure/restoring_divider.v
rtl/microstructure/bram_microstructure.v
rtl/microstructure/hw_quantizer.v

